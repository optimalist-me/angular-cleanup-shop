{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@cleanup/feature-marketing-home": [
        "libs/marketing/feature-marketing-home/src/index.ts"
      ],
      "@cleanup/ui-marketing-hero": [
        "libs/marketing/ui-marketing-hero/src/index.ts"
      ],
      "@cleanup/ui-marketing-section": [
        "libs/marketing/ui-marketing-section/src/index.ts"
      ],
      "@cleanup/feature-marketing-playbook": [
        "libs/marketing/feature-marketing-playbook/src/index.ts"
      ],
      "@cleanup/feature-marketing-architecture": [
        "libs/marketing/feature-marketing-architecture/src/index.ts"
      ],
      "@cleanup/shared-ui-header": ["libs/shared/ui-header/src/index.ts"],
      "@cleanup/shared-ui-footer": ["libs/shared/ui-footer/src/index.ts"],
      "@cleanup/feature-marketing-faq": [
        "libs/marketing/feature-marketing-faq/src/index.ts"
      ],
      "@cleanup/data-access-products": [
        "libs/products/data-access-products/src/index.ts"
      ],
      "@cleanup/ui-product-card": [
        "libs/products/ui-product-card/src/index.ts"
      ],
      "@cleanup/ui-product-tag": ["libs/products/ui-product-tag/src/index.ts"],
      "@cleanup/feature-products-list": [
        "libs/products/feature-products-list/src/index.ts"
      ],
      "@cleanup/feature-product-detail": [
        "libs/products/feature-product-detail/src/index.ts"
      ],
      "@cleanup/data-access-cart": ["libs/cart/data-access-cart/src/index.ts"],
      "@cleanup/ui-cart-line-item": [
        "libs/cart/ui-cart-line-item/src/index.ts"
      ],
      "@cleanup/ui-cart-summary": ["libs/cart/ui-cart-summary/src/index.ts"],
      "@cleanup/feature-cart": ["libs/cart/feature-cart/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
